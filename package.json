{
  "name": "model-lock",
  "version": "0.1.0",
  "description": "package-lock.json for AI model dependencies",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Rabbott LLC",
    "url": "https://github.com/vibe-code-commit/model-lock"
  },
  "contributors": [
    {
      "name": "Rabbott LLC",
      "url": "https://github.com/vibe-code-commit/model-lock"
    }
  ],
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "model-lock": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "data/registry",
    "data/official",
    "action.yml",
    "LICENSE",
    "README.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:live": "vitest run --project live",
    "schemas": "tsx scripts/generate-schemas.ts",
    "seed:registry": "tsx scripts/seed-registry.ts",
    "check-all": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "registry:refresh": "tsx scripts/registry-refresh.ts",
    "prepublishOnly": "npm run build && npm run check-all"
  },
  "keywords": [
    "ai",
    "llm",
    "lockfile",
    "ci",
    "model-lock",
    "openai",
    "anthropic",
    "xai",
    "google"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibe-code-commit/model-lock.git"
  },
  "bugs": {
    "url": "https://github.com/vibe-code-commit/model-lock/issues"
  },
  "homepage": "https://github.com/vibe-code-commit/model-lock#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.0",
    "commander": "^14.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/babel__traverse": "^7.20.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.6",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "fast-check": "^4.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}
